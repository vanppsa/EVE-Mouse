# Maintainer: Everton <vanppsa@users.noreply.github.com>
pkgname=eve-mouse
pkgver=__VERSION__
pkgrel=1
pkgdesc="Control mouse and keyboard from your phone over Wi-Fi"
arch=('any')
url="https://github.com/vanppsa/EVE-Mouse"
license=('MIT')
depends=('python>=3.10' 'python-gobject' 'gtk4' 'ydotool' 'python-pip' 'python-virtualenv')
source=("$pkgname-$pkgver.tar.gz::https://github.com/vanppsa/EVE-Mouse/archive/v$pkgver.tar.gz")

package() {
    cd "${srcdir}/EVE-Mouse-${pkgver}"

    install -dm755 "${pkgdir}/opt/eve-mouse"
    cp -r app main.py requirements.txt 99-eve-mouse-uinput.rules "${pkgdir}/opt/eve-mouse/"

    install -Dm755 packaging/eve-mouse.sh "${pkgdir}/usr/bin/eve-mouse"

    install -Dm644 packaging/eve-mouse.desktop "${pkgdir}/usr/share/applications/com.eve.mouse.desktop"

    install -Dm644 app/static/icons/com.eve.mouse.png "${pkgdir}/usr/share/icons/hicolor/256x256/apps/com.eve.mouse.png"

    install -Dm755 packaging/postinstall.sh "${pkgdir}/usr/share/eve-mouse/postinstall.sh"
    install -Dm755 packaging/prerm.sh "${pkgdir}/usr/share/eve-mouse/prerm.sh"
}

post_install() {
    bash /usr/share/eve-mouse/postinstall.sh 2>/dev/null || true
}

post_remove() {
    bash /usr/share/eve-mouse/prerm.sh remove 2>/dev/null || true
}
